{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TransactionEvent",
  "description": "Event emitted when a financial transaction is processed",
  "type": "object",
  "properties": {
    "transactionId": {
      "type": "string",
      "description": "Unique identifier for the transaction (idempotency key)"
    },
    "accountId": {
      "type": "string",
      "description": "Source account identifier"
    },
    "amount": {
      "type": "number",
      "description": "Transaction amount in cents (positive integer)"
    },
    "currency": {
      "type": "string",
      "description": "ISO 4217 currency code",
      "pattern": "^[A-Z]{3}$"
    },
    "type": {
      "type": "string",
      "enum": ["deposit", "withdrawal", "transfer", "payment"],
      "description": "Transaction type"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the transaction occurred"
    },
    "metadata": {
      "type": "object",
      "description": "Optional free-form metadata",
      "additionalProperties": true
    }
  },
  "required": ["transactionId", "accountId", "amount", "currency", "type", "timestamp"]
}
